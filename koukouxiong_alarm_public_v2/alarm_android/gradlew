#!/bin/bash
export ANDROID_HOME=~/android-sdk
export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
GRADLE_USER_HOME=~/.gradle
GRADLE_WRAPPER_JAR="$GRADLE_USER_HOME/wrapper/dists/gradle-8.5-bin/*/gradle-8.5/bin/gradle"
if [ ! -f "$GRADLE_WRAPPER_JAR" ]; then
    curl -sL https://services.gradle.org/distributions/gradle-8.5-bin.zip -o /tmp/gradle.zip
    unzip -q /tmp/gradle.zip -d /tmp
    export PATH=/tmp/gradle-8.5/bin:$PATH
else
    export PATH=$(dirname "$GRADLE_WRAPPER_JAR"):$PATH
fi
gradle "$@"
